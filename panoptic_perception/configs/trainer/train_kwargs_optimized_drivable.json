{
    "_description": "Optimized config for joint detection + drivable + lane detection training",

    "model_kwargs":{
        "model_type":"yolop",
        "cfg_path":"panoptic_perception/configs/models/yolo-lane-detect.cfg",
        "device":"cuda:0"
    },

    "dataset_kwargs":{
        "images_dir": "/workspace/data/bdd100k_images/100k/100k",
        "detection_annotations_dir": "/workspace/data/bdd100k_labels/100k",
        "segmentation_annotations_dir": "",
        "drivable_annotations_dir": "/workspace/data/bdd100k_drivable_maps/labels",
        "train_batch_size": 16,
        "train_shuffle": true,
        "train_num_workers": 4,
        "train_preprocessor_kwargs":{
            "image_resize": [640, 640],
            "original_image_size": [720, 1280],
            "perform_augmentation": true,
            "augment_params": {
                "degrees": 5,
                "translate": 0.05,
                "scale": 0.15,
                "shear": 2,
                "hsv_h": 0.015,
                "hsv_s": 0.7,
                "hsv_v": 0.4,
                "salt_prob": 0.005,
                "pepper_prob": 0.005,
                "flip_prob": 0.5,
                "img_size": [640, 640]
            },
            "advanced_aug": {
                "mosaic_prob": 0.0,
                "mixup_prob": 0.0,
                "copy_paste_prob": 0.0
            }
        },
        "val_batch_size": 16,
        "val_shuffle": false,
        "val_num_workers": 4,
        "val_preprocessor_kwargs":{
            "image_resize": [640, 640],
            "original_image_size": [720, 1280]
        }
    },

    "optimizer_kwargs":{
        "_description": "AdamW optimizer - all layers trainable for joint training",
        "_type": "AdamW",
        "initial_lr": 1e-3,
        "weight_decay": 0.01,
        "momentum": 0.937,
        "warmup_bias_lr": 0.1,
        "warmup_momentum": 0.8,
        "warmup_epochs": 3,
        "groups": {}
    },

    "lr_scheduler_kwargs":{
        "_type": "cosine",
        "linear_lr_kwargs":{
            "start_factor": 1.0,
            "end_factor": 0.01
        },
        "cosine_annealing_lr_kwargs":{
            "eta_min": 5e-6
        }
    },

    "trainer_kwargs":{
        "output_dir": "yolop-lane-detect",
        "is_training": true,
        "first_val_epoch": 0,
        "metric_eval_mode": "strict",
        "metric_average_mode": "macro",
        "epochs": 100,
        "monitor_train": true,
        "monitor_val": true,
        "gradient_clipping": 1.0,
        "checkpoint_idx": 2,
        "gradient_accumulation_steps": 2,
        "lr_scheduler_start_epoch": 1,
        "reload_optimizer": false,
        "reload_optimizer_with_initial_lr": false,

        "wandb_project": "yolop-lane-detect",
        "wandb_enabled": true,
        "use_ema": false,
        "ema_decay": 0.9999,
        "ema_warmup_steps": 2000
    },

    "loss_weights": {
        "_description": "Multi-task loss weights",
        "detection": 1.0,
        "drivable_segmentation": 1.0,
        "lane_detection": 1.0,
        "lane_segmentation": 0.0
    }
}
