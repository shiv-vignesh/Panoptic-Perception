{
    "_description": "Optimized config for joint detection + drivable training with advanced augmentations",

    "model_kwargs":{
        "model_type":"yolop",
        "cfg_path":"/workspace/Panoptic-Perception/panoptic_perception/configs/models/yolo-768-1280-detection.cfg",
        "device":"cuda:0",
        "use_gdip": false,
        "use_denet": true,
        "denet_kwargs": {
            "num_high": 3,
            "gaussian_kernel_size": 5,
            "num_channels": 3,
            "channel_blocks": 64,
            "channel_mask": 16,
            "high_channels": 32,
            "high_kernel_size": 3,
            "visualize_intermediate": true
        }
    },

    "dataset_kwargs":{
        "dataset_class": "foggy",
        "depth_map_dir": null,
        "strict_map": false,
        "apply_fog_prob": 0.67,
        "adverse_params": {
            "fog_betas": [0.008, 0.015, 0.025, 0.040],
            "darkness_gammas": [1.3, 1.5, 2.0],
            "atmospheric_light": [0.9, 0.9, 0.9],
            "enable_fog_only": true,
            "enable_darkness_only": true,
            "enable_compound": true,
            "depth_backend": "depth_anything",
            "depth_device": "cuda",
            "onnx_backend_path": null,
            "max_depth_meters": 150.0
        },
        "images_dir": "/workspace/data/100k/100k",
        "detection_annotations_dir": "/workspace/data/bdd100k_labels/100k",
        "segmentation_annotations_dir": "",
        "drivable_annotations_dir": "/workspace/data/drivable_maps/labels",
        "train_batch_size": 8,
        "train_shuffle": true,
        "train_num_workers": 4,
        "train_preprocessor_kwargs":{
            "image_resize": [768, 1280],
            "original_image_size": [720, 1280],
            "perform_augmentation": true,
            "augment_params": {
                "degrees": 10,
                "translate": 0.1,
                "scale": 0.25,
                "shear": 5,
                "hsv_h": 0.015,
                "hsv_s": 0.7,
                "hsv_v": 0.4,
                "salt_prob": 0.005,
                "pepper_prob": 0.005,
                "flip_prob": 0.5,
                "img_size": [768, 1280]
            },
            "advanced_aug": {
                "mosaic_prob": 0.0,
                "mixup_prob": 0.0,
                "copy_paste_prob": 0.0
            }
        },
        "val_batch_size": 16,
        "val_shuffle": false,
        "val_num_workers": 4,
        "val_preprocessor_kwargs":{
            "image_resize": [768, 1280],
            "original_image_size": [720, 1280]
        }
    },

    "optimizer_kwargs":{
        "_description": "AdamW optimizer - all layers trainable for joint training",
        "_type": "AdamW",
        "initial_lr": 1e-3,
        "weight_decay": 0.01,
        "momentum": 0.937,
        "warmup_bias_lr": 0.1,
        "warmup_momentum": 0.8,
        "warmup_epochs": 3,
        "groups": {
            "backbone": {
                "group": [0, 23],
                "trainable": true
            },
            "detect": {
                "group": [24],
                "trainable": true
            },
            "segmentation": {
                "group": [25, 33],
                "trainable": false
            }
        }
    },

    "lr_scheduler_kwargs":{
        "_type": "cosine",
        "linear_lr_kwargs":{
            "start_factor": 1.0,
            "end_factor": 0.01
        },
        "cosine_annealing_lr_kwargs":{
            "eta_min": 1e-6
        }
    },

    "trainer_kwargs":{
        "output_dir": "DENET-yolov5p-768-1280-Heuristic-HeavyFog",
        "eval_visualize_outputs":true,
        "is_training": true,
        "first_val_epoch": 0,
        "metric_eval_mode": "strict",
        "metric_average_mode": "macro",
        "epochs": 100,
        "monitor_train": true,
        "monitor_val": true,
        "gradient_clipping": 1.0,
        "checkpoint_idx": 2,
        "gradient_accumulation_steps": 4,
        "lr_scheduler_start_epoch": 1,
        "checkpoint_path": "/workspace/Panoptic-Perception/yolop-detection-768x1280-new-anchors/best_model.pt",
        "reload_optimizer": false,
        "reload_optimizer_with_initial_lr": false,
        "lambda_defog": 0.6,

        "wandb_project": "DENET-YOLOP-detection",
        "wandb_enabled": true,
        "use_ema": false,
        "ema_decay": 0.9999,
        "ema_warmup_steps": 2000
    },

    "loss_kwargs": {
        "detection":{
            "_type":"detection-loss-ATSS",
            "kwargs":{}
        },
        "drivable_segmentation":{
            "_type":"segmentation-loss",
            "kwargs":{}
        },
        "lane_detection":{
            "_type":"lane-detection-loss",
            "kwargs":{}
        },
        "loss_weights": {
            "_description": "Multi-task loss weights",
            "detection": 1.0,
            "drivable_segmentation": 1.0,
            "lane_detection": 1.0,
            "lane_segmentation": 0.0
        }        
    }
}
