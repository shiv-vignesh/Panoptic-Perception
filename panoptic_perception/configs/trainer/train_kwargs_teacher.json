{
    "_description": "Teacher fusion training — privileged information (clean image + depth). Production config for Vast 2x RTX 5060 Ti.",

    "image_model_kwargs": {
        "model_type": "yolop",
        "cfg_path": "/workspace/Panoptic-Perception/panoptic_perception/configs/models/teacher_model/image_backbone.cfg",
        "device": "cuda:1",
        "backbone_init": ""
    },

    "depth_model_kwargs": {
        "model_type": "yolop",
        "cfg_path": "/workspace/Panoptic-Perception/panoptic_perception/configs/models/teacher_model/depth_backbone.cfg",
        "device": "cuda:1",
        "backbone_init": ""
    },

    "fusion_kwargs": {
        "backbone_intercepts": { "detection": [[17, 128], [20, 256], [23, 512]] },
        "fusion_type": "attention",
        "weighted_fusion": false,
        "num_fusion_blocks": 1,
        "aux_depth_recon_cfg": "/workspace/Panoptic-Perception/panoptic_perception/configs/models/teacher_model/depth_recon.cfg"
    },

    "dataset_kwargs": {
        "dataset_class": "foggy",
        "apply_fog":     false,
        "collate_path":  "gpu",
        "adverse_params": {
            "depth_backend": "depth_anything",
            "depth_device":  "cuda"
        },
        "images_dir":                   "../data/100k/100k",
        "detection_annotations_dir":    "../data/bdd100k_labels/100k",
        "segmentation_annotations_dir": "",
        "drivable_annotations_dir":     "../data/drivable_maps/labels",
        "train_batch_size":  8,
        "train_shuffle":     true,
        "train_num_workers": 0,
        "train_preprocessor_kwargs": {
            "image_resize":         [512, 512],
            "original_image_size":  [720, 1280],
            "perform_augmentation": true,
            "augment_params": {
                "degrees": 5, "translate": 0.05, "scale": 0.15, "shear": 2,
                "hsv_h": 0.015, "hsv_s": 0.7, "hsv_v": 0.4,
                "salt_prob": 0.005, "pepper_prob": 0.005,
                "flip_prob": 0.5,
                "img_size": [512, 512]
            },
            "advanced_aug": {"mosaic_prob": 0.0, "mixup_prob": 0.0, "copy_paste_prob": 0.0}
        },
        "val_batch_size":   8,
        "val_shuffle":      false,
        "val_num_workers":  0,
        "val_preprocessor_kwargs": {
            "image_resize":         [512, 512],
            "original_image_size":  [720, 1280]
        }
    },

    "optimizer_kwargs": {
        "_type":          "AdamW",
        "initial_lr":     1e-3,
        "weight_decay":   0.01,
        "momentum":       0.937,
        "warmup_bias_lr": 0.1,
        "warmup_momentum": 0.8,
        "warmup_epochs":  3,
        "image_backbone_kwargs": {
            "groups": {
                "backbone":     {"group": [0, 9],   "trainable": true},
                "fpn":          {"group": [10, 16], "trainable": true},
                "det_pan":      {"group": [17, 23], "trainable": true},
                "detect_head":  {"group": [24],     "trainable": true},
                "segmentation": {"group": [25, 33], "trainable": true}
            }
        },
        "depth_backbone_kwargs": {
            "groups": {
                "backbone":     {"group": [0, 9],   "trainable": true},
                "fpn":          {"group": [10, 16], "trainable": true},
                "det_pan":      {"group": [17, 23], "trainable": true},
                "detect_head":  {"group": [24],     "trainable": false},
                "segmentation": {"group": [25, 33], "trainable": false}
            }
        },
        "fusion_lr_scale": 1.0
    },

    "lr_scheduler_kwargs": {
        "_type": "cosine",
        "linear_lr_kwargs":           {"start_factor": 1.0, "end_factor": 0.01},
        "cosine_annealing_lr_kwargs": {"eta_min": 5e-6}
    },

    "trainer_kwargs": {
        "output_dir":           "yolop-teacher-fusion-numBlocks=3-ColdStart",
        "is_training":          true,
        "first_val_epoch":      0,
        "metric_eval_mode":     "strict",
        "metric_average_mode":  "macro",
        "epochs":               100,
        "monitor_train":        true,
        "monitor_val":          true,
        "gradient_clipping":    1.0,
        "checkpoint_idx":       2,
        "gradient_accumulation_steps": 2,
        "lr_scheduler_start_epoch":    1,
        "reload_optimizer":            false,
        "reload_optimizer_with_initial_lr": false,
        "checkpoint_path":             null,
        "wandb_project":               "teacher-fusion",
        "wandb_enabled":               true,
        "use_ema":                     false,
        "ema_decay":                   0.9999,
        "ema_warmup_steps":            2000
    },

    "loss_kwargs": {
        "detection":             {"_type": "detection-loss-anchor", "kwargs": {}},
        "drivable_segmentation": {"_type": "segmentation-loss",   "kwargs": {}},
        "lane_detection":        {"_type": "lane-detection-loss", "kwargs": {}},
        "depth_reconstruction":  {
            "_type": "depth-reconstruction",
            "kwargs": {
                "loss_type": "smooth_l1",
                "aux_weights": {"17": 0.3, "20": 0.4, "23": 0.5},
                "full_res_weight": 1.0
            }
        },
        "loss_weights": {
            "detection":             1.0,
            "drivable_segmentation": 1.0,
            "lane_detection":        1.0,
            "lane_segmentation":     0.0,
            "depth_reconstruction":  0.5
        }
    }
}
